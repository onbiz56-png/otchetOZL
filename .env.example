# Google Sheets
GOOGLE_SHEET_ID=вставь_id_таблицы_из_ссылки
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
# Приватный ключ из JSON сервисного аккаунта, целиком, со \n вместо переносов строк
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# Telegram
TELEGRAM_BOT_TOKEN=токен_от_BotFather
TELEGRAM_CHAT_ID=твой_личный_chat_id
# Необязательно: ограничить доступ только тебе (твой Telegram user id)
ALLOWED_TELEGRAM_USER_ID=
